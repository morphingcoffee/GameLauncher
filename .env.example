# Copy to .env for local overrides (never commit .env)
# On macOS, prefer storing real values in Keychain — see .cursor/skills/secret-hygiene/SKILL.md

# Remote manifest URL override (public CDN endpoint, no auth params)
GAME_LAUNCHER_MANIFEST_URL=https://host-endpoint.com/manifest.json

# GitHub PAT: store in Keychain only — source scripts/github-pat-from-keychain.sh
# Do NOT put GITHUB_PAT or GITHUB_TOKEN in this file.
